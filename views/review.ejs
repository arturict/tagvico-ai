<%
  function escapeHtml(value) {
    if (value === null || value === undefined) return '';
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  const rows = Array.isArray(analyses) ? analyses : [];
  const isReviewFirst = typeof reviewMode === 'boolean' ? reviewMode : dryRun;
  const banner = isReviewFirst
    ? 'Automatic writes are paused. Apply sends only the reviewed suggestion to Paperless-ngx.'
    : 'Automatic writes are enabled. Suggestions already in this queue still require an explicit decision.';

  function hasOwn(object, key) {
    return Boolean(object) && Object.prototype.hasOwnProperty.call(object, key);
  }

  function renderValue(value) {
    if (value === null || value === undefined || value === '') return '<span class="metric-footnote">—</span>';
    if (Array.isArray(value)) {
      return value.length > 0
        ? value.map((item) => `<span class="badge">${escapeHtml(item)}</span>`).join(' ')
        : '<span class="metric-footnote">None</span>';
    }
    if (typeof value === 'object') {
      return `<code style="white-space:pre-wrap;overflow-wrap:anywhere;">${escapeHtml(JSON.stringify(value))}</code>`;
    }
    return escapeHtml(value);
  }

  function renderOtherChanges(proposal) {
    const entries = Object.entries(proposal || {})
      .filter(([key]) => !['title', 'tags', 'correspondent'].includes(key));
    if (entries.length === 0) return '<span class="metric-footnote">—</span>';
    return entries.map(([key, value]) => `
      <div style="margin-bottom:0.35rem;">
        <strong>${escapeHtml(key.replace(/_/g, ' '))}:</strong> ${renderValue(value)}
      </div>
    `).join('');
  }

  const tableBody = rows.length === 0
    ? '<tr class="review-empty"><td colspan="7" style="text-align:center;padding:1.5rem;">No pending suggestions.</td></tr>'
    : rows.map((row) => {
        const proposal = row.proposed_metadata && typeof row.proposed_metadata === 'object'
          ? row.proposed_metadata
          : {};
        const titleText = hasOwn(proposal, 'title')
          ? renderValue(proposal.title)
          : '<span class="metric-footnote">Unchanged</span>';
        const tagsText = hasOwn(proposal, 'tags')
          ? renderValue(proposal.tags)
          : '<span class="metric-footnote">Unchanged</span>';
        const correspondentText = hasOwn(proposal, 'correspondent')
          ? renderValue(proposal.correspondent)
          : '<span class="metric-footnote">Unchanged</span>';
        return `
          <tr data-suggestion-id="${escapeHtml(row.id)}" data-document-id="${escapeHtml(row.document_id)}">
            <td><input type="checkbox" class="review-row-select" data-suggestion-id="${escapeHtml(row.id)}" data-document-id="${escapeHtml(row.document_id)}" aria-label="Select suggestion ${escapeHtml(row.id)}"></td>
            <td>
              <a href="/manual/preview/${escapeHtml(row.document_id)}" target="_blank" rel="noreferrer">#${escapeHtml(row.document_id)}</a>
              <div class="metric-footnote">Suggestion #${escapeHtml(row.id)}</div>
            </td>
            <td>${titleText}</td>
            <td>${tagsText}</td>
            <td>${correspondentText}</td>
            <td>${renderOtherChanges(proposal)}</td>
            <td>
              <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                <button type="button" class="button review-apply" data-suggestion-id="${escapeHtml(row.id)}" data-document-id="${escapeHtml(row.document_id)}">Apply</button>
                <button type="button" class="button-secondary review-reject" data-suggestion-id="${escapeHtml(row.id)}" data-document-id="${escapeHtml(row.document_id)}">Reject</button>
              </div>
            </td>
          </tr>
        `;
      }).join('');

  const body = `
    <section class="page-header">
      <div>
        <p class="section-kicker">Review queue</p>
        <h1 class="page-title">Review queue</h1>
        <p class="page-subtitle">Inspect stored AI suggestions before they reach Paperless-ngx. ${escapeHtml(banner)}</p>
        ${typeof error !== 'undefined' && error ? `<p class="alert alert-error">${escapeHtml(error)}</p>` : ''}
      </div>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
        <button id="applySelectedBtn" class="button" type="button">Apply selected</button>
        <button id="refreshBtn" class="button-secondary" type="button">Refresh</button>
      </div>
    </section>

    <section class="card stack">
      <div style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th></th>
              <th>Doc</th>
              <th>Title</th>
              <th>Tags</th>
              <th>Correspondent</th>
              <th>Other changes</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="reviewTableBody">
            ${tableBody}
          </tbody>
        </table>
      </div>
    </section>
  `;

  const extraScripts = `
    <script>
      (function () {
        const table = document.getElementById('reviewTableBody');
        if (!table) return;
        const events = new EventSource('/api/review/progress');
        events.addEventListener('progress', function (event) {
          const progress = JSON.parse(event.data || '{}');
          if (!progress.suggestionId) return;
          const row = table.querySelector('tr[data-suggestion-id="' + progress.suggestionId + '"]');
          if (row) row.dataset.status = progress.status;
        });

        function ensureEmptyState() {
          if (!table.querySelector('tr[data-suggestion-id]')) {
            table.innerHTML = '<tr class="review-empty"><td colspan="7" style="text-align:center;padding:1.5rem;">No pending suggestions.</td></tr>';
          }
        }

        function setRowBusy(suggestionId, busy) {
          const row = table.querySelector('tr[data-suggestion-id="' + suggestionId + '"]');
          if (!row) return;
          row.querySelectorAll('button, input').forEach(function (control) {
            control.disabled = busy;
          });
        }

        async function decideOne(suggestionId, documentId, action) {
          setRowBusy(suggestionId, true);
          try {
            const response = await fetch('/review/' + encodeURIComponent(suggestionId) + '/' + action, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({})
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(payload.reason || payload.error || 'unknown error');
            }
            const row = table.querySelector('tr[data-suggestion-id="' + suggestionId + '"]');
            if (row) row.remove();
            ensureEmptyState();
            return true;
          } catch (err) {
            alert(action.charAt(0).toUpperCase() + action.slice(1) + ' failed for document #' + documentId + ': ' + err.message);
            setRowBusy(suggestionId, false);
            return false;
          }
        }

        table.addEventListener('click', function (event) {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          if (target.classList.contains('review-apply')) {
            const suggestionId = target.getAttribute('data-suggestion-id');
            const documentId = target.getAttribute('data-document-id');
            if (suggestionId && documentId) decideOne(suggestionId, documentId, 'apply');
          } else if (target.classList.contains('review-reject')) {
            const suggestionId = target.getAttribute('data-suggestion-id');
            const documentId = target.getAttribute('data-document-id');
            if (suggestionId && documentId && window.confirm('Reject the suggestion for document #' + documentId + '?')) {
              decideOne(suggestionId, documentId, 'reject');
            }
          }
        });

        const applySelectedBtn = document.getElementById('applySelectedBtn');
        if (applySelectedBtn) {
          applySelectedBtn.addEventListener('click', async function () {
            const checkboxes = Array.from(table.querySelectorAll('.review-row-select:checked'));
            applySelectedBtn.disabled = true;
            for (const cb of checkboxes) {
              const suggestionId = cb.getAttribute('data-suggestion-id');
              const documentId = cb.getAttribute('data-document-id');
              if (suggestionId && documentId) await decideOne(suggestionId, documentId, 'apply');
            }
            applySelectedBtn.disabled = false;
          });
        }

        const refreshBtn = document.getElementById('refreshBtn');
        if (refreshBtn) {
          refreshBtn.addEventListener('click', function () {
            window.location.reload();
          });
        }
      })();
    </script>
  `;
%>
<%- include('partials/app-shell', {
  title: title || 'Review | Tagvico AI',
  activePage: 'review',
  version,
  includeCharts: false,
  includeDataTables: false,
  extraHead: '',
  extraScripts,
  body
}) %>
