{
  "name": "tagvico-ai",
  "version": "2.0.0-alpha.1",
  "description": "Tagvico AI — alpha. Self-hosted AI autopilot for Paperless-ngx (metadata, tagging, classification, owner assignment). Active development; APIs and schema may change without notice.",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "auth:copilot": "node scripts/copilot-login.js",
    "dev": "npm run build && nodemon --watch services --watch routes --watch models --watch config --watch server.ts --ext ts,json --exec \"npm run build && node dist/server.js\"",
    "build": "tsc",
    "test": "npm run check && npm run test:unit",
    "test:unit": "npm run build && node --test tests/*.test.js",
    "check": "npm run typecheck && npm run lint && npm run check:type-debt && npm run check:ejs && npm run check:browser",
    "check:browser": "node --check public/js/config-form.js && node --check public/js/app-shell.js",
    "check:ejs": "node scripts/check-ejs.js",
    "check:type-debt": "node scripts/check-type-debt.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint eslint.config.mjs"
  },
  "keywords": [
    "paperless-ngx",
    "ai",
    "paperless",
    "artificial",
    "intelligence"
  ],
  "nodemonConfig": {
    "ignore": [
      "test/*",
      "docs/*",
      "node_modules/*",
      ".git/*",
      "*.log",
      "public/*",
      "views/*",
      "document.json",
      "OPENAPI/openapi.json"
    ]
  },
  "author": "arturict",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@github/copilot-sdk": "^1.0.6",
    "@openai/codex-sdk": "^0.144.1",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.5.0",
    "nodemon": "^3.1.9",
    "openai": "^4.86.2",
    "parseurl": "^1.3.3",
    "rimraf": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tiktoken": "^1.0.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jsdoc": "^50.6.3",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "better-sqlite3"
    ]
  }
}
