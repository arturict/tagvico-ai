{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "rootDir": "."
  },
  "include": [
    "services/**/*.ts",
    "routes/**/*.ts",
    "scripts/**/*.ts",
    "schemas.ts",
    "server.ts"
  ],
  "exclude": [
    "node_modules",
    "data",
    "public",
    "docs"
  ]
}
