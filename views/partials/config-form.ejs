<%
  const isSetup = mode === 'setup';
  const formAction = isSetup ? '/setup' : '/settings';
  const submitLabel = isSetup ? 'Finish setup' : 'Save changes';
  const introTitle = isSetup ? 'Set up Tagvico AI' : 'Configuration';
  const introCopy = isSetup
    ? 'Connect Paperless-ngx, choose a model, and decide what Tagvico AI may write back. The rest uses smart defaults.'
    : 'Switch providers, refresh model choices, and control how aggressively Tagvico AI updates documents.';
  const providerLogos = {
    openrouter: { light: 'https://svgl.app/library/openrouter_light.svg', dark: 'https://svgl.app/library/openrouter_dark.svg' },
    ollama: { light: 'https://svgl.app/library/ollama_light.svg', dark: 'https://svgl.app/library/ollama_dark.svg' },
    'ollama-cloud': { light: 'https://svgl.app/library/ollama_light.svg', dark: 'https://svgl.app/library/ollama_dark.svg' },
    opencode: { light: 'https://svgl.app/library/openai.svg', dark: 'https://svgl.app/library/openai_dark.svg' },
    copilot: { light: 'https://svgl.app/library/github.svg', dark: 'https://svgl.app/library/github_dark.svg' },
    compatible: { light: 'https://svgl.app/library/openai.svg', dark: 'https://svgl.app/library/openai_dark.svg' },
    openai: { light: 'https://svgl.app/library/openai.svg', dark: 'https://svgl.app/library/openai_dark.svg' },
    azure: { light: 'https://svgl.app/library/azure.svg', dark: 'https://svgl.app/library/azure.svg' },
    anthropic: { light: 'https://svgl.app/library/anthropic_black.svg', dark: 'https://svgl.app/library/anthropic_white.svg' },
    codex: { light: 'https://svgl.app/library/codex_light.svg', dark: 'https://svgl.app/library/codex_dark.svg' }
  };
%>

<section class="page-header">
  <div>
    <p class="section-kicker"><%= isSetup ? 'Onboarding' : 'Settings' %></p>
    <h1 class="page-title"><%= introTitle %></h1>
    <p class="page-subtitle"><%= introCopy %></p>
  </div>
  <div class="badge-row">
    <span class="badge"><i class="fa-solid fa-code-branch"></i> <%= config.ARCHIVISTA_AI_VERSION %></span>
    <span class="badge"><i class="fa-solid fa-wand-magic-sparkles"></i> Default model: <%= providerCatalog.recommendedModel %></span>
  </div>
</section>

<% if (success) { %>
<div class="success" style="margin-bottom:1rem;" role="status"><%= success %></div>
<% } %>

<% if (settingsError || error) { %>
<div class="danger" style="margin-bottom:1rem;" role="alert"><%= settingsError || error %></div>
<% } %>

<form id="configForm" class="stack" data-mode="<%= mode %>" data-action="<%= formAction %>">
  <% if (isSetup) { %>
  <ol class="onboarding-strip" aria-label="Setup steps">
    <li class="onboarding-step is-active"><span>1</span><strong>Scan</strong><small>Find Paperless</small></li>
    <li class="onboarding-step"><span>2</span><strong>Token</strong><small>Paste API key</small></li>
    <li class="onboarding-step"><span>3</span><strong>Model</strong><small>Pick default</small></li>
    <li class="onboarding-step"><span>4</span><strong>Run</strong><small>Auto-file docs</small></li>
  </ol>
  <% } %>

  <fieldset class="section-fieldset stack cube-hero">
    <legend>
      <span class="section-kicker">1. Paperless connection</span>
      <span class="legend-title">Connect your Paperless-ngx instance</span>
    </legend>

    <div class="form-grid">
      <div class="field">
        <label for="paperlessUrl">Paperless URL</label>
        <input id="paperlessUrl" name="paperlessUrl" type="url" required value="<%= config.PAPERLESS_API_URL %>" placeholder="https://paperless.example.com" autocomplete="url">
        <p class="field-hint">Only the base URL. `/api` is added automatically.</p>
      </div>

      <div class="field">
        <label for="paperlessToken">API token</label>
        <div class="secret-input">
          <input id="paperlessToken" name="paperlessToken" type="password" required value="<%= config.PAPERLESS_API_TOKEN %>" placeholder="Paste one Paperless API token" autocomplete="off">
          <button type="button" class="secret-toggle" data-toggle-secret="paperlessToken" aria-label="Show Paperless API token"><i class="fa-solid fa-eye"></i></button>
        </div>
        <p class="field-hint">
          <a id="openPaperlessTokenLink" href="#" target="_blank" rel="noopener" class="inline-link">
            <i class="fa-solid fa-up-right-from-square"></i> Open Paperless-ngx to copy your API token
          </a>
        </p>
      </div>

      <div class="field">
        <label for="paperlessUsername">Paperless username</label>
        <input id="paperlessUsername" name="paperlessUsername" type="text" value="<%= config.PAPERLESS_USERNAME %>" placeholder="Tagvico AI" autocomplete="username">
      </div>

      <div class="field">
        <label for="scanInterval">Scan interval</label>
        <input id="scanInterval" name="scanInterval" type="text" value="<%= config.SCAN_INTERVAL %>" placeholder="*/30 * * * *" inputmode="text">
        <p class="field-hint">Cron syntax. Default scans every 30 minutes.</p>
      </div>
    </div>

    <div class="discovery-row">
      <button type="button" id="discoverPaperlessBtn" class="button-secondary">
        <i class="fa-solid fa-magnifying-glass"></i> Scan for Paperless-ngx instances
      </button>
      <button type="button" id="testPaperlessBtn" class="button-secondary">
        <i class="fa-solid fa-plug-circle-check"></i> Test connection
      </button>
      <span id="paperlessDiscoveryStatus" class="field-hint" aria-live="polite"></span>
    </div>
    <div id="paperlessDiscoveryResults" class="discovery-results hidden"></div>
  </fieldset>

  <fieldset class="section-fieldset stack" id="controlledTaggingSection">
    <legend>
      <span class="section-kicker">Controlled tagging</span>
      <span class="legend-title">Choose the vocabulary AI may assign</span>
    </legend>
    <div class="form-grid">
      <div class="field">
        <label for="controlledTaggingEnabled">Tagging policy</label>
        <select id="controlledTaggingEnabled" name="controlledTaggingEnabled" required>
          <% if (isSetup && !config.TAG_GROUPS_JSON) { %><option value="" selected disabled>Choose a tagging policy</option><% } %>
          <option value="no" <%= config.CONTROLLED_TAGGING_ENABLED !== 'yes' ? 'selected' : '' %>>Open tagging (legacy)</option>
          <option value="yes" <%= config.CONTROLLED_TAGGING_ENABLED === 'yes' ? 'selected' : '' %>>Controlled vocabulary</option>
        </select>
      </div>
      <div class="field">
        <label for="tagMaxPerDocument">Maximum AI tags per document</label>
        <input id="tagMaxPerDocument" name="tagMaxPerDocument" type="number" min="1" max="10" value="<%= config.TAG_MAX_PER_DOCUMENT || 3 %>">
      </div>
    </div>
    <input id="tagGroupsJson" name="tagGroupsJson" type="hidden" value="<%= JSON.stringify(config.TAG_GROUPS || []) %>">
    <input id="tagGroupDefaults" type="hidden" value="<%= JSON.stringify(config.TAG_GROUP_PRESETS || []) %>">
    <div class="tag-policy-summary" aria-live="polite">
      <strong id="enabledTagCount">0 enabled tags</strong>
      <span id="tagDuplicateWarning" class="danger hidden"></span>
    </div>
    <div id="tagGroupEditor" class="tag-group-grid"></div>
    <button type="button" id="addTagGroup" class="button-secondary"><i class="fa-solid fa-plus"></i> Add custom group</button>
    <% if (!isSetup) { %>
    <details class="advanced-panel">
      <summary><strong>Exception review and unmanaged Paperless tags</strong></summary>
      <div id="tagExceptionReview" class="stack"><p class="field-hint">Loading tag exceptions…</p></div>
      <div id="unmanagedTags" class="stack"><p class="field-hint">Loading unmanaged tags…</p></div>
    </details>
    <% } %>
  </fieldset>

  <% if (isSetup) { %>
  <fieldset class="section-fieldset stack">
    <legend>
      <span class="section-kicker">2. Local login</span>
      <span class="legend-title">Create a tiny local admin</span>
    </legend>

    <div class="form-grid">
      <div class="field">
        <label for="username">Admin username</label>
        <input id="username" name="username" type="text" autocomplete="username" required>
      </div>

      <div class="field">
        <label for="password">Admin password</label>
        <div class="secret-input">
          <input id="password" name="password" type="password" autocomplete="new-password" required>
          <button type="button" class="secret-toggle" data-toggle-secret="password" aria-label="Show admin password"><i class="fa-solid fa-eye"></i></button>
        </div>
      </div>
    </div>
  </fieldset>
  <% } %>

  <fieldset class="section-fieldset stack">
    <legend>
      <span class="section-kicker"><%= isSetup ? '3. Model provider' : 'Model provider' %></span>
      <span class="legend-title">Choose how Tagvico AI talks to AI</span>
    </legend>

    <input id="aiProvider" name="aiProvider" type="hidden" value="<%= providerCatalog.selectedProvider %>">
    <input id="aiModel" name="aiModel" type="hidden" value="<%= providerCatalog.effectiveModel %>">

    <button type="button" id="openModelPicker" class="model-picker-trigger" aria-haspopup="dialog" aria-controls="modelPickerModal">
      <span class="model-picker-mark"><i class="fa-solid fa-cube"></i></span>
      <span class="model-picker-current">
        <small>Active model</small>
        <strong id="activeModelName"><%= providerCatalog.effectiveModel || 'Choose a model' %></strong>
        <span id="activeProviderName"><%= providerCatalog.providers.find((provider) => provider.selected)?.name || 'Provider' %></span>
      </span>
      <span class="model-picker-action">Change <kbd>⌘ K</kbd></span>
    </button>

    <div id="modelPickerModal" class="model-picker-modal is-provider-step" role="dialog" aria-modal="true" aria-labelledby="modelPickerTitle" aria-hidden="true">
      <button type="button" class="model-picker-backdrop" data-close-model-picker aria-label="Close model picker"></button>
      <div class="model-picker-shell">
        <header class="model-picker-header">
          <button type="button" id="modelPickerBack" class="model-picker-back hidden" aria-label="Back to providers"><i class="fa-solid fa-arrow-left"></i></button>
          <div class="model-picker-heading">
            <p class="section-kicker">AI connection</p>
            <h2 id="modelPickerTitle">Connect a provider</h2>
          </div>
          <button type="button" class="model-picker-close" data-close-model-picker aria-label="Close model picker"><i class="fa-solid fa-xmark"></i></button>
        </header>
        <div class="model-picker-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input id="modelPickerSearch" type="search" placeholder="Search providers or models…" autocomplete="off" aria-label="Search providers and models">
          <kbd>Esc</kbd>
        </div>
        <div class="model-picker-layout">
          <aside id="providerChoices" class="provider-rail" role="radiogroup" aria-label="Model provider">
      <% providerCatalog.providers.forEach((provider) => { %>
      <button type="button" class="provider-rail-item <%= provider.selected ? 'is-selected' : '' %>" role="radio" aria-checked="<%= provider.selected ? 'true' : 'false' %>" data-provider-choice="<%= provider.id %>" data-search-text="<%= `${provider.name} ${provider.description}`.toLowerCase() %>">
        <span class="provider-rail-icon">
          <img class="provider-logo provider-logo-light" src="<%= providerLogos[provider.id].light %>" alt="" width="24" height="24" loading="lazy">
          <img class="provider-logo provider-logo-dark" src="<%= providerLogos[provider.id].dark %>" alt="" width="24" height="24" loading="lazy">
        </span>
        <span class="provider-rail-copy">
          <strong><%= provider.name %></strong>
          <small><%= provider.supportsModelDiscovery ? 'Discover models' : provider.supportsCustomModelSlug ? 'Custom models' : 'Curated models' %></small>
        </span>
          <% if (provider.recommended) { %><span class="badge">Recommended</span><% } %>
        <i class="fa-solid fa-chevron-right provider-rail-chevron"></i>
      </button>
      <% }) %>
          </aside>

          <div id="providerPanels" class="model-picker-detail stack">
      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'openrouter' ? '' : 'hidden' %>" data-provider-panel="openrouter" aria-hidden="<%= providerCatalog.selectedProvider === 'openrouter' ? 'false' : 'true' %>">
        <h3>OpenRouter</h3>
        <p class="field-hint">Best default for this app. Use the curated small-model list or paste your own OpenRouter slug.</p>

        <div class="form-grid">
          <div class="field field-wide">
            <label for="openrouterApiKey">OpenRouter API key</label>
            <div class="secret-input">
              <input id="openrouterApiKey" name="openrouterApiKey" type="password" value="<%= config.OPENROUTER_API_KEY %>" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="openrouterApiKey" aria-label="Show OpenRouter API key"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>

          <div class="field field-wide">
            <span id="openrouterPresetLabel" class="field-hint" style="font-weight:600;color:var(--text);">Curated models</span>
            <div id="openrouterPresetGrid" class="segmented model-grid" role="radiogroup" aria-labelledby="openrouterPresetLabel">
              <% providerCatalog.openrouterPresets.forEach((preset) => { %>
              <button type="button" class="choice-card model-choice <%= providerCatalog.effectiveModel === preset.slug ? 'is-selected' : '' %>" role="radio" aria-checked="<%= providerCatalog.effectiveModel === preset.slug ? 'true' : 'false' %>" data-model-choice="<%= preset.slug %>">
                <div class="choice-title">
                  <span><%= preset.name %></span>
                </div>
                <div class="choice-copy"><%= preset.summary %></div>
                <div class="badge-row" style="margin-top:0.65rem;">
                  <% preset.badges.forEach((badge) => { %>
                  <span class="badge"><%= badge %></span>
                  <% }) %>
                </div>
              </button>
              <% }) %>
            </div>
          </div>

          <div class="field field-wide">
            <label for="openrouterCustomModel">Custom OpenRouter slug</label>
            <input id="openrouterCustomModel" type="text" placeholder="openai/gpt-5.4-nano" value="<%= !providerCatalog.selectedPreset && providerCatalog.selectedProvider === 'openrouter' ? providerCatalog.effectiveModel : '' %>">
            <p class="field-hint">Useful for trying a fresh model from OpenRouter without waiting for a preset update.</p>
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'ollama' ? '' : 'hidden' %>" data-provider-panel="ollama" aria-hidden="<%= providerCatalog.selectedProvider === 'ollama' ? 'false' : 'true' %>">
        <h3>Ollama</h3>
        <p class="field-hint">Supports local instances and remote Ollama hosts. Fetch models directly from the selected endpoint.</p>

        <div class="form-grid">
          <div class="field field-wide">
            <label for="ollamaUrl">Ollama URL</label>
            <input id="ollamaUrl" name="ollamaUrl" type="url" value="<%= config.OLLAMA_API_URL %>" placeholder="http://localhost:11434">
          </div>

          <div class="field field-wide">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
              <label for="ollamaModelSelect">Available models</label>
              <button type="button" class="button-secondary" id="refreshOllamaModels">Refresh models</button>
            </div>
            <select id="ollamaModelSelect"></select>
          </div>

          <div class="field field-wide">
            <label for="ollamaCustomModel">Or enter a model manually</label>
            <input id="ollamaCustomModel" type="text" value="<%= config.OLLAMA_MODEL %>" placeholder="llama3.2">
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'ollama-cloud' ? '' : 'hidden' %>" data-provider-panel="ollama-cloud" aria-hidden="<%= providerCatalog.selectedProvider === 'ollama-cloud' ? 'false' : 'true' %>">
        <h3>Ollama Cloud</h3>
        <p class="field-hint">Use an Ollama API key for hosted cloud models without exposing a local Ollama instance. Your document text is sent to Ollama Cloud.</p>
        <div class="form-grid">
          <div class="field field-wide">
            <label for="ollamaCloudUrl">Ollama Cloud URL</label>
            <input id="ollamaCloudUrl" name="ollamaCloudUrl" type="url" value="<%= config.OLLAMA_CLOUD_API_URL %>" placeholder="https://ollama.com">
          </div>
          <div class="field">
            <label for="ollamaCloudApiKey">Ollama API key</label>
            <div class="secret-input">
              <input id="ollamaCloudApiKey" name="ollamaCloudApiKey" type="password" value="<%= config.OLLAMA_CLOUD_API_KEY %>" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="ollamaCloudApiKey" aria-label="Show Ollama Cloud API key"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>
          <div class="field">
            <label for="ollamaCloudModel">Cloud model</label>
            <input id="ollamaCloudModel" name="ollamaCloudModel" type="text" value="<%= config.OLLAMA_CLOUD_MODEL %>" placeholder="gpt-oss:20b-cloud">
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'opencode' ? '' : 'hidden' %>" data-provider-panel="opencode" aria-hidden="<%= providerCatalog.selectedProvider === 'opencode' ? 'false' : 'true' %>">
        <h3>OpenCode Go</h3>
        <p class="field-hint">Use a Console service API key. Tagvico talks to OpenCode’s OpenAI-compatible inference gateway directly—no OpenCode CLI is required.</p>
        <div class="form-grid">
          <div class="field field-wide">
            <label for="opencodeBaseUrl">Inference gateway</label>
            <input id="opencodeBaseUrl" name="opencodeBaseUrl" type="url" value="<%= config.OPENCODE_BASE_URL %>" placeholder="https://console.opencode.ai/inference/openai/v1">
          </div>
          <div class="field">
            <label for="opencodeApiKey">OpenCode service API key</label>
            <div class="secret-input">
              <input id="opencodeApiKey" name="opencodeApiKey" type="password" value="<%= config.OPENCODE_API_KEY %>" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="opencodeApiKey" aria-label="Show OpenCode service API key"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>
          <div class="field">
            <label for="opencodeModel">Model ID</label>
            <input id="opencodeModel" name="opencodeModel" type="text" value="<%= config.OPENCODE_MODEL %>" placeholder="Use a model your Console catalog permits">
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'copilot' ? '' : 'hidden' %>" data-provider-panel="copilot" aria-hidden="<%= providerCatalog.selectedProvider === 'copilot' ? 'false' : 'true' %>">
        <h3>GitHub Copilot <span class="badge">Subscription</span></h3>
        <p class="field-hint">Runs through GitHub’s official Copilot SDK with all tools disabled. Use a fine-grained GitHub token/OAuth user token, or sign in with <code>copilot auth login</code> in the container and leave this blank.</p>
        <div class="form-grid">
          <div class="field field-wide">
            <label for="copilotGitHubToken">GitHub access token (optional after CLI sign-in)</label>
            <div class="secret-input">
              <input id="copilotGitHubToken" name="copilotGitHubToken" type="password" value="<%= config.COPILOT_GITHUB_TOKEN %>" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="copilotGitHubToken" aria-label="Show GitHub Copilot token"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>
          <div class="field">
            <label for="copilotModel">Copilot model</label>
            <input id="copilotModel" name="copilotModel" type="text" value="<%= config.COPILOT_MODEL %>" placeholder="gpt-5.4">
            <p class="field-hint">Good low-cost options include GPT-5.4 or Claude Haiku 4.5 when your plan exposes them.</p>
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'compatible' ? '' : 'hidden' %>" data-provider-panel="compatible" aria-hidden="<%= providerCatalog.selectedProvider === 'compatible' ? 'false' : 'true' %>">
        <h3>OpenAI-compatible API</h3>
        <p class="field-hint">Works for LM Studio, LiteLLM, vLLM, FastChat, and most OpenAI-compatible gateways.</p>

        <div class="form-grid">
          <div class="field field-wide">
            <label for="compatibleBaseUrl">Base URL</label>
            <input id="compatibleBaseUrl" name="compatibleBaseUrl" type="url" value="<%= config.COMPATIBLE_BASE_URL %>" placeholder="http://localhost:1234/v1">
          </div>

          <div class="field">
            <label for="compatibleApiKey">API key</label>
            <div class="secret-input">
              <input id="compatibleApiKey" name="compatibleApiKey" type="password" value="<%= config.COMPATIBLE_API_KEY %>" placeholder="optional for some local gateways" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="compatibleApiKey" aria-label="Show compatible API key"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>

          <div class="field">
            <label for="compatibleModel">Model slug</label>
            <input id="compatibleModel" type="text" value="<%= config.COMPATIBLE_MODEL %>" placeholder="qwen2.5-14b-instruct">
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'openai' ? '' : 'hidden' %>" data-provider-panel="openai" aria-hidden="<%= providerCatalog.selectedProvider === 'openai' ? 'false' : 'true' %>">
        <h3>OpenAI direct</h3>
        <p class="field-hint">Use native OpenAI access when you do not want OpenRouter in the middle.</p>

        <div class="form-grid">
          <div class="field">
            <label for="openaiKey">OpenAI API key</label>
            <div class="secret-input">
              <input id="openaiKey" name="openaiKey" type="password" value="<%= config.OPENAI_API_KEY %>" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="openaiKey" aria-label="Show OpenAI API key"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>

          <div class="field">
            <label for="openaiModel">Model</label>
            <select id="openaiModel">
              <% providerCatalog.openaiDirectModels.forEach((model) => { %>
              <option value="<%= model.slug %>" <%= config.OPENAI_MODEL === model.slug || providerCatalog.effectiveModel === model.slug ? 'selected' : '' %>><%= model.name %></option>
              <% }) %>
            </select>
            <p class="field-hint">OpenAI Direct is intentionally locked to supported GPT-5.x models. GPT-5.6 Sol, Terra, and Luna appear only for trusted-preview organizations with <code>OPENAI_ENABLE_GPT_5_6_PREVIEW=yes</code>.</p>
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'anthropic' ? '' : 'hidden' %>" data-provider-panel="anthropic" aria-hidden="<%= providerCatalog.selectedProvider === 'anthropic' ? 'false' : 'true' %>">
        <h3>Anthropic direct</h3>
        <p class="field-hint">Use Claude synchronously or through Anthropic Message Batches.</p>
        <div class="form-grid">
          <div class="field">
            <label for="anthropicApiKey">Anthropic API key</label>
            <div class="secret-input">
              <input id="anthropicApiKey" name="anthropicApiKey" type="password" value="<%= config.ANTHROPIC_API_KEY %>" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="anthropicApiKey" aria-label="Show Anthropic API key"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>
          <div class="field">
            <label for="anthropicModel">Claude model</label>
            <input id="anthropicModel" type="text" value="<%= config.ANTHROPIC_MODEL %>" placeholder="claude-haiku-4-5">
          </div>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'codex' ? '' : 'hidden' %>" data-provider-panel="codex" aria-hidden="<%= providerCatalog.selectedProvider === 'codex' ? 'false' : 'true' %>">
        <h3>Codex subscription <span class="badge">Experimental</span></h3>
        <p class="field-hint">Uses the official Codex runtime. Tokens stay in the configured Codex home and are never exposed to this page.</p>
        <div class="inline-actions">
          <button id="codexStatusButton" type="button" class="button-secondary">Check login status</button>
          <button id="codexLoginButton" type="button" class="button-secondary">Sign in with ChatGPT</button>
          <button id="codexLogoutButton" type="button" class="button-danger">Sign out</button>
          <span id="codexStatusResult" class="field-hint" aria-live="polite"></span>
        </div>
        <div id="codexLoginResult" class="field-hint" aria-live="polite"></div>
        <div id="codexLoginChallenge" class="codex-device-card hidden" aria-live="polite">
          <div class="codex-device-topline">
            <span class="codex-device-status"><span class="codex-device-pulse"></span> Waiting for authorization</span>
            <span class="codex-device-step">1 minute setup</span>
          </div>
          <p class="codex-device-label">Your one-time device code</p>
          <button id="codexCopyCode" type="button" class="codex-device-code" aria-label="Copy device code">
            <span id="codexDeviceCode"></span>
            <span class="codex-copy-hint"><kbd>C</kbd> Copy</span>
          </button>
          <div class="codex-device-actions">
            <a id="codexOpenAuth" class="button-primary" href="#" target="_blank" rel="noopener noreferrer">
              Open ChatGPT <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
            <button id="codexCopyCodeButton" type="button" class="button-secondary">
              <i class="fa-regular fa-copy"></i> Copy code
            </button>
          </div>
          <p id="codexCopyFeedback" class="codex-copy-feedback">Open ChatGPT, then paste the code when asked.</p>
        </div>
        <div class="field">
          <label for="codexModel">Codex model</label>
          <input id="codexModel" type="text" value="<%= config.CODEX_MODEL %>" placeholder="gpt-5.4-mini">
          <p class="field-hint">Codex is optimized for agentic coding, not document classification. Use this only if you accept the experimental quality and latency trade-offs.</p>
        </div>
      </section>

      <section class="provider-panel stack section-fieldset <%= providerCatalog.selectedProvider === 'azure' ? '' : 'hidden' %>" data-provider-panel="azure" aria-hidden="<%= providerCatalog.selectedProvider === 'azure' ? 'false' : 'true' %>">
        <h3>Azure OpenAI</h3>
        <p class="field-hint">Legacy path for existing Azure-backed setups.</p>

        <div class="form-grid">
          <div class="field field-wide">
            <label for="azureEndpoint">Endpoint</label>
            <input id="azureEndpoint" name="azureEndpoint" type="url" value="<%= config.AZURE_ENDPOINT %>">
          </div>

          <div class="field">
            <label for="azureApiKey">API key</label>
            <div class="secret-input">
              <input id="azureApiKey" name="azureApiKey" type="password" value="<%= config.AZURE_API_KEY %>" autocomplete="off">
              <button type="button" class="secret-toggle" data-toggle-secret="azureApiKey" aria-label="Show Azure API key"><i class="fa-solid fa-eye"></i></button>
            </div>
          </div>

          <div class="field">
            <label for="azureDeploymentName">Deployment name</label>
            <input id="azureDeploymentName" name="azureDeploymentName" type="text" value="<%= config.AZURE_DEPLOYMENT_NAME %>">
          </div>

          <div class="field field-wide">
            <label for="azureApiVersion">API version</label>
            <input id="azureApiVersion" name="azureApiVersion" type="text" value="<%= config.AZURE_API_VERSION %>">
          </div>
        </div>
      </section>
          </div>
        </div>
        <footer class="model-picker-footer" id="modelPickerFooter">
          <span><i class="fa-solid fa-circle-info"></i> Credentials stay encrypted in your local configuration.</span>
          <button type="button" id="applyModelPicker" class="button-primary">Use this model <i class="fa-solid fa-arrow-right"></i></button>
        </footer>
      </div>
    </div>

    <div class="field field-wide">
      <label for="aiProcessingMode">Cost and processing mode</label>
      <select id="aiProcessingMode" name="aiProcessingMode">
        <option value="standard" <%= config.AI_PROCESSING_MODE === 'standard' ? 'selected' : '' %>>Standard — process immediately</option>
        <option value="flex" <%= config.AI_PROCESSING_MODE === 'flex' ? 'selected' : '' %>>OpenAI Flex — lower cost, slower and capacity-dependent</option>
        <option value="batch" <%= config.AI_PROCESSING_MODE === 'batch' ? 'selected' : '' %>>Batch — asynchronous, discounted, up to 24 hours</option>
      </select>
      <p class="field-hint">Flex is available only for supported OpenAI models. Batch is available for OpenAI Direct and Anthropic Direct; Tagvico groups documents discovered in the same scan.</p>
    </div>

    <div class="field field-wide">
      <label for="aiReasoningEffort">Thinking effort for GPT-5 models</label>
      <select id="aiReasoningEffort" name="aiReasoningEffort">
        <option value="minimal" <%= config.AI_REASONING_EFFORT === 'minimal' ? 'selected' : '' %>>Minimal</option>
        <option value="low" <%= config.AI_REASONING_EFFORT === 'low' ? 'selected' : '' %>>Low</option>
        <option value="medium" <%= config.AI_REASONING_EFFORT === 'medium' ? 'selected' : '' %>>Medium</option>
      </select>
      <p class="field-hint">Applies when the selected model supports GPT-5-style reasoning effort. Default stays low.</p>
    </div>
  </fieldset>

  <fieldset class="section-fieldset stack">
    <legend>
      <span class="section-kicker"><%= isSetup ? '4. Filing behavior' : 'Filing behavior' %></span>
      <span class="legend-title">Decide what Tagvico AI writes back</span>
    </legend>

    <div class="segmented" role="group" aria-label="Fields Tagvico AI may write back">
      <label class="choice-card toggle-card <%= config.ACTIVATE_TAGGING === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="activateTagging" <%= config.ACTIVATE_TAGGING === 'yes' ? 'checked' : '' %> hidden aria-label="Generate and attach tags">
        <div class="choice-title"><span>Tags</span></div>
        <div class="choice-copy">Generate and attach tags.</div>
      </label>

      <label class="choice-card toggle-card <%= config.ACTIVATE_CORRESPONDENTS === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="activateCorrespondents" <%= config.ACTIVATE_CORRESPONDENTS === 'yes' ? 'checked' : '' %> hidden aria-label="Infer the sender or issuer">
        <div class="choice-title"><span>Correspondent</span></div>
        <div class="choice-copy">Infer the sender or issuer.</div>
      </label>

      <label class="choice-card toggle-card <%= config.ACTIVATE_DOCUMENT_TYPE === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="activateDocumentType" <%= config.ACTIVATE_DOCUMENT_TYPE === 'yes' ? 'checked' : '' %> hidden aria-label="Classify document types">
        <div class="choice-title"><span>Document type</span></div>
        <div class="choice-copy">Classify invoices, contracts, letters, and similar types.</div>
      </label>

      <label class="choice-card toggle-card <%= config.ACTIVATE_TITLE === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="activateTitle" <%= config.ACTIVATE_TITLE === 'yes' ? 'checked' : '' %> hidden aria-label="Rewrite titles">
        <div class="choice-title"><span>Title</span></div>
        <div class="choice-copy">Rewrite titles into something clearer.</div>
      </label>

      <label class="choice-card toggle-card <%= config.ACTIVATE_CUSTOM_FIELDS === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="activateCustomFields" <%= config.ACTIVATE_CUSTOM_FIELDS === 'yes' ? 'checked' : '' %> hidden aria-label="Populate custom fields">
        <div class="choice-title"><span>Custom fields</span></div>
        <div class="choice-copy">Populate your own Paperless custom fields.</div>
      </label>

      <label class="choice-card toggle-card <%= config.ACTIVATE_OWNER_ASSIGNMENT === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="activateOwnerAssignment" <%= config.ACTIVATE_OWNER_ASSIGNMENT === 'yes' ? 'checked' : '' %> hidden aria-label="Assign documents to matching users">
        <div class="choice-title"><span>Person assignment</span><span class="badge">Optional</span></div>
        <div class="choice-copy">Assign documents to matching Paperless users. Works automatically from user names; hints are optional.</div>
      </label>
    </div>

    <div class="form-grid">
      <div class="field">
        <label for="useExistingData">Reuse existing Paperless metadata</label>
        <select id="useExistingData" name="useExistingData">
          <option value="no" <%= config.USE_EXISTING_DATA === 'no' ? 'selected' : '' %>>No</option>
          <option value="yes" <%= config.USE_EXISTING_DATA === 'yes' ? 'selected' : '' %>>Yes</option>
        </select>
      </div>

      <div class="field">
        <label for="disableAutomaticProcessing">Automatic processing</label>
        <select id="disableAutomaticProcessing" name="disableAutomaticProcessing">
          <option value="no" <%= config.DISABLE_AUTOMATIC_PROCESSING === 'no' ? 'selected' : '' %>>Enabled</option>
          <option value="yes" <%= config.DISABLE_AUTOMATIC_PROCESSING === 'yes' ? 'selected' : '' %>>Manual only</option>
        </select>
      </div>

      <div class="field">
        <label for="aiProcessedTag">AI processed tag</label>
        <select id="aiProcessedTag" name="aiProcessedTag">
          <option value="no" <%= config.ADD_AI_PROCESSED_TAG === 'no' ? 'selected' : '' %>>Off</option>
          <option value="yes" <%= config.ADD_AI_PROCESSED_TAG === 'yes' ? 'selected' : '' %>>On</option>
        </select>
      </div>

      <div class="field">
        <label for="aiTagName">Processed tag name</label>
        <input id="aiTagName" name="aiTagName" type="text" value="<%= config.AI_PROCESSED_TAG_NAME %>" placeholder="ai-processed">
      </div>

      <div class="field">
        <label for="showTags">Only process selected tags</label>
        <select id="showTags" name="showTags">
          <option value="no" <%= config.PROCESS_PREDEFINED_DOCUMENTS === 'no' ? 'selected' : '' %>>Process all documents</option>
          <option value="yes" <%= config.PROCESS_PREDEFINED_DOCUMENTS === 'yes' ? 'selected' : '' %>>Only tagged documents</option>
        </select>
      </div>

      <div class="field">
        <label for="tags">Document trigger tags</label>
        <input id="tags" name="tags" type="text" value="<%= Array.isArray(config.TAGS) ? config.TAGS.join(', ') : '' %>" placeholder="invoice, tax, todo-ai">
      </div>
    </div>
  </fieldset>

  <details class="hero stack advanced-panel">
    <summary>
      <span>
        <span class="section-kicker">Advanced</span>
        <strong>Person hints</strong>
      </span>
      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
    </summary>

    <div>
      <p class="field-hint">Optional. Tagvico already compares document text with each Paperless user name and email. Add hints only when a person has aliases, departments, or keywords that are not obvious from their account.</p>
    </div>

    <div class="form-grid">
      <div class="field field-wide">
        <label for="ownerProfiles">Extra matching hints</label>
        <textarea id="ownerProfiles" name="ownerProfiles" rows="7" placeholder="alex: Alex M., private invoices, health insurance&#10;finance: accounting team, vendor bills, receipts"><%= config.OWNER_PROFILES %></textarea>
        <div class="help-card">
          <strong>How this works</strong>
          <p>Left side is an existing Paperless username. Right side is optional text that may appear in documents for that user.</p>
          <p>Example: <code>alex: Alex M., private invoices, health insurance</code></p>
          <p>If you are unsure, leave it blank and let automatic matching handle it.</p>
        </div>
      </div>
    </div>
  </details>

  <details class="hero stack advanced-panel">
    <summary>
      <span>
        <span class="section-kicker">Advanced</span>
        <strong>Guardrails and enrichment</strong>
      </span>
      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
    </summary>

    <div class="segmented" role="group" aria-label="Guardrails that restrict AI suggestions">
      <label class="choice-card toggle-card <%= config.RESTRICT_TO_EXISTING_TAGS === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="restrictToExistingTags" <%= config.RESTRICT_TO_EXISTING_TAGS === 'yes' ? 'checked' : '' %> hidden aria-label="Only existing tags">
        <div class="choice-title"><span>Only existing tags</span></div>
        <div class="choice-copy">Prevents new tags from being created by AI.</div>
      </label>

      <label class="choice-card toggle-card <%= config.RESTRICT_TO_EXISTING_CORRESPONDENTS === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="restrictToExistingCorrespondents" <%= config.RESTRICT_TO_EXISTING_CORRESPONDENTS === 'yes' ? 'checked' : '' %> hidden aria-label="Only existing correspondents">
        <div class="choice-title"><span>Only existing correspondents</span></div>
        <div class="choice-copy">Keeps correspondent suggestions inside your current Paperless data.</div>
      </label>

      <label class="choice-card toggle-card <%= config.RESTRICT_TO_EXISTING_DOCUMENT_TYPES === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="restrictToExistingDocumentTypes" <%= config.RESTRICT_TO_EXISTING_DOCUMENT_TYPES === 'yes' ? 'checked' : '' %> hidden aria-label="Only existing document types">
        <div class="choice-title"><span>Only existing document types</span></div>
        <div class="choice-copy">Avoids creating new Paperless document types automatically.</div>
      </label>

      <label class="choice-card toggle-card <%= config.EXTERNAL_API_ENABLED === 'yes' ? 'is-selected' : '' %>">
        <input type="checkbox" name="externalApiEnabled" <%= config.EXTERNAL_API_ENABLED === 'yes' ? 'checked' : '' %> hidden aria-label="Enable external enrichment">
        <div class="choice-title"><span>External enrichment</span></div>
        <div class="choice-copy">Attach extra API data to the analysis prompt before filing.</div>
      </label>
    </div>

    <div class="form-grid">
      <div class="field field-wide">
        <label for="externalApiUrl">External API URL</label>
        <input id="externalApiUrl" name="externalApiUrl" type="url" value="<%= config.EXTERNAL_API_URL %>" placeholder="https://api.example.com/lookup">
      </div>

      <div class="field">
        <label for="externalApiMethod">HTTP method</label>
        <select id="externalApiMethod" name="externalApiMethod">
          <option value="GET" <%= config.EXTERNAL_API_METHOD === 'GET' ? 'selected' : '' %>>GET</option>
          <option value="POST" <%= config.EXTERNAL_API_METHOD === 'POST' ? 'selected' : '' %>>POST</option>
          <option value="PUT" <%= config.EXTERNAL_API_METHOD === 'PUT' ? 'selected' : '' %>>PUT</option>
        </select>
      </div>

      <div class="field">
        <label for="externalApiTimeout">Timeout in ms</label>
        <input id="externalApiTimeout" name="externalApiTimeout" type="number" value="<%= config.EXTERNAL_API_TIMEOUT %>" inputmode="numeric">
      </div>

      <div class="field field-wide">
        <label for="externalApiHeaders">Headers JSON</label>
        <textarea id="externalApiHeaders" name="externalApiHeaders" rows="4"><%= config.EXTERNAL_API_HEADERS %></textarea>
      </div>

      <div class="field field-wide">
        <label for="externalApiBody">Body JSON</label>
        <textarea id="externalApiBody" name="externalApiBody" rows="4"><%= config.EXTERNAL_API_BODY %></textarea>
      </div>

      <div class="field field-wide">
        <label for="externalApiTransform">Transform function</label>
        <textarea id="externalApiTransform" name="externalApiTransform" rows="6"><%= config.EXTERNAL_API_TRANSFORM %></textarea>
      </div>
    </div>
  </details>

  <details class="hero stack advanced-panel">
    <summary>
      <span>
        <span class="section-kicker">Advanced</span>
        <strong>Custom fields</strong>
      </span>
      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
    </summary>

    <div>
      <p class="field-hint">Define the Paperless custom fields you want AI to fill when it can confidently extract them.</p>
    </div>

    <div id="customFieldList" class="stack"></div>

    <div class="form-grid">
      <div class="field">
        <label for="newFieldName">Field name</label>
        <input id="newFieldName" type="text" placeholder="Invoice amount">
      </div>

      <div class="field">
        <label for="newFieldType">Field type</label>
        <select id="newFieldType">
          <option value="string">Text</option>
          <option value="float">Number</option>
          <option value="integer">Integer</option>
          <option value="monetary">Currency</option>
        </select>
      </div>

      <div class="field">
        <label for="currencyCode">Currency code</label>
        <select id="currencyCode">
          <option value="EUR">EUR</option>
          <option value="USD">USD</option>
          <option value="GBP">GBP</option>
          <option value="CHF">CHF</option>
        </select>
      </div>

      <div class="field" style="align-self:end;">
        <button type="button" id="addCustomField" class="button-secondary">Add field</button>
      </div>
    </div>

    <input id="customFieldsJson" name="customFields" type="hidden" value='<%= config.CUSTOM_FIELDS || "{\"custom_fields\":[]}" %>'>
  </details>

  <div class="save-bar">
    <p class="save-hint">Saved settings apply to new processing runs immediately. No app restart is needed.</p>
    <button type="submit" class="button" id="configSubmit"><%= submitLabel %></button>
  </div>
</form>
