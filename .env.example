PAPERLESS_API_URL=http://paperless:8000
PAPERLESS_API_TOKEN=
TAGVICO_AI_PORT=3000
TAGVICO_AI_HOST_PORT=8080
# Periodic Action Center reconciliation (cron syntax).
ACTION_SYNC_INTERVAL=*/10 * * * *
# Maximum original-document bytes buffered by optional OCR (default 50 MiB, hard cap 100 MiB).
OCR_MAX_FILE_BYTES=52428800
API_KEY=
JWT_SECRET=
CORS_ORIGINS=
TRUST_PROXY=no
ALLOW_REMOTE_SETUP=no
GLOBAL_RATE_LIMIT_MAX=1000
# Optional anonymous installation analytics. Off unless explicitly enabled.
TAGVICO_TELEMETRY_ENABLED=no
# Configure only after deploying the receiver in telemetry/ with valid HTTPS.
TAGVICO_TELEMETRY_ENDPOINT=
# review (default) queues suggestions; automatic writes validated metadata directly.
TAGVICO_WRITE_MODE=review
# Automatic scanning is enabled unless this is set to yes.
DISABLE_AUTOMATIC_PROCESSING=no
SCAN_INTERVAL=*/30 * * * *
# Trigger tags are optional. Empty scans every new unprocessed document.
PROCESS_PREDEFINED_DOCUMENTS=no
TAGS=
# Four is the default hard ceiling in both open and controlled tagging.
TAG_MAX_PER_DOCUMENT=4
# Optional archive-specific instructions. The maintained general prompt remains active.
CUSTOM_PROMPT=
# Advanced override for the general system role. Safety and output contracts stay enforced.
SYSTEM_PROMPT=
# Legacy deployments may continue using DRY_RUN=true/false.
AI_PROVIDER=openrouter
# Companion runtime provider. Defaults to AI_PROVIDER. Supported values:
# openrouter, ollama, ollama-cloud, opencode, copilot, compatible, openai, codex.
COMPANION_PROVIDER=opencode
AI_MODEL=openai/gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# GPT-5.6 Sol/Terra/Luna are trusted-partner preview models, not a broad default.
# OPENAI_ENABLE_GPT_5_6_PREVIEW=yes
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.4-mini
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_API_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=gpt-oss:20b-cloud
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=deepseek-v4-flash
COPILOT_GITHUB_TOKEN=
COPILOT_HOME=/app/data/copilot
COPILOT_MODEL=gpt-5.4-mini
COMPATIBLE_BASE_URL=http://host.docker.internal:1234/v1
COMPATIBLE_API_KEY=
COMPATIBLE_MODEL=
CODEX_HOME=/app/data/codex
# Used by the optional read-only Codex SDK adapter.
CODEX_MODEL=gpt-5.4-mini

# Optional private Telegram interface. Disabled unless explicitly enabled.
# Each allowlisted user gets an independent Paperless token and conversation.
TELEGRAM_BOT_ENABLED=no
TELEGRAM_BOT_TOKEN=
# Example: [{"telegramId":"123456789","paperlessToken":"token-for-that-user","householdId":"...","memberId":"..."}]
# paperlessUrl is optional per user and otherwise uses PAPERLESS_API_URL.
# householdId/memberId enable /actions and approval cards for that user.
TELEGRAM_USERS_JSON=[]
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_UPLOAD_TIMEOUT_SECONDS=180
TELEGRAM_MAX_DOCUMENTS=8
TELEGRAM_HISTORY_TURNS=6
TELEGRAM_MAX_FILE_BYTES=20971520
# Explicit opt-in: AI metadata from Telegram uploads bypasses the web review queue.
TELEGRAM_UPLOAD_AUTOMATIC_METADATA=no
