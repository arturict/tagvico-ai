<%
  const s = summary || {};
  const counts = s.counts || { documents: 0, processed: 0, remaining: 0, processedPct: 0, tags: 0, correspondents: 0 };
  const tokens = s.tokens || { avgPrompt: 0, avgCompletion: 0, avgTotal: 0, overall: 0, promptPct: 0, completionPct: 0, promptRatio: 0 };
  const cost = s.cost || { available: false, isEstimate: true, source: 'none', model: '', currency: 'USD', rate: { input: 0, output: 0 }, inputCost: 0, outputCost: 0, total: 0, perDocument: 0 };
  const hasMetrics = tokens.overall > 0 || tokens.avgTotal > 0;
  const fmtUsd = (value, digits = 2) => `$${Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: digits, maximumFractionDigits: digits })}`;
  const fmtCents = (value) => {
    const n = Number(value || 0);
    if (n > 0 && n < 0.01) return '<$0.01';
    return fmtUsd(n, n < 1 ? 4 : 2);
  };
  const dashboardJson = JSON.stringify(summary || {})
    .replace(/</g, '\\u003c')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');

  const body = `
    <section class="dash-intro">
      <div>
        <p class="section-kicker">Operations overview</p>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">What Tagvico AI has processed, how much model budget it burns, and what is still waiting for action.</p>
      </div>
      <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
        <div id="scanResult" class="success hidden" role="status">Scan triggered successfully.</div>
        <button id="scanButton" class="button" type="button"><i class="fa-solid fa-wand-magic-sparkles"></i><span>Scan now</span></button>
      </div>
    </section>

    <div class="dash-identity" aria-hidden="true">
      <span class="dash-mark"></span>
      <span>Tagvico AI ${version} &middot; live processing state polls every few seconds</span>
    </div>

    <p class="dash-group-title">Throughput at a glance</p>
    <section class="kpi-strip" aria-label="Processing throughput">
      <article class="kpi">
        <div class="kpi-label">Processed</div>
        <div class="kpi-value">${counts.processed.toLocaleString()}</div>
        <div class="kpi-context"><strong>${counts.processedPct}%</strong> of ${counts.documents.toLocaleString()} visible${counts.remaining > 0 ? ` &middot; <span class="kpi-warn">${counts.remaining.toLocaleString()} still unfiled and waiting</span>` : ' &middot; all caught up'}</div>
      </article>
      <article class="kpi">
        <div class="kpi-label">Processed today</div>
        <div class="kpi-value" id="processingToday">0</div>
        <div class="kpi-context">From scheduled and manual scans since midnight.</div>
      </article>
      ${cost.available ? `
      <article class="kpi">
        <div class="kpi-label">Estimated spend${cost.isEstimate ? ' *' : ''}</div>
        <div class="kpi-value">${fmtUsd(cost.total)}</div>
        <div class="kpi-context"><strong>${fmtCents(cost.perDocument)}</strong> / document &middot; ${cost.model}</div>
      </article>` : `
      <article class="kpi">
        <div class="kpi-label">Estimated spend</div>
        <div class="kpi-value">&mdash;</div>
        <div class="kpi-context">${counts.correspondents >= 0 ? 'No billable model usage tracked yet.' : ''}</div>
      </article>`}
      <article class="kpi">
        <div class="kpi-label">Tags in Paperless</div>
        <div class="kpi-value">${counts.tags.toLocaleString()}</div>
        <div class="kpi-context"><button id="showTagsButton" class="button-secondary" type="button" style="margin-top:0.4rem;">Inspect tag activity</button></div>
      </article>
      <article class="kpi">
        <div class="kpi-label">Correspondents</div>
        <div class="kpi-value">${counts.correspondents.toLocaleString()}</div>
        <div class="kpi-context"><button id="showCorrespondentsButton" class="button-secondary" type="button" style="margin-top:0.4rem;">Inspect correspondents</button></div>
      </article>
    </section>

    <section class="card-grid">
      <article class="card chart-card span-5" aria-label="Processing progress">
        <div class="chart-head">
          <div>
            <div class="chart-title">Processing progress</div>
            <div class="chart-sub">Completed vs remaining documents visible to Tagvico AI.</div>
          </div>
        </div>
        <div class="chart-canvas" id="processingChart"></div>
        <div id="processingLegend" class="chart-legend" aria-hidden="true"></div>
      </article>

      <article class="card runner-card span-7" aria-label="Runner state">
        <div class="chart-head">
          <div>
            <div class="chart-title">Runner state</div>
            <div class="chart-sub">Current task and most recent completion.</div>
          </div>
          <div class="runner-state" id="processingStateWrap"><span class="runner-pulse"></span><span id="processingState">Idle</span></div>
        </div>
        <div class="runner-row">
          <span>Current document</span>
          <span class="choice-copy" id="processingCurrent">No active document</span>
        </div>
        <div class="runner-row">
          <span>Last processed</span>
          <span class="choice-copy" id="processingLast">No processed documents yet</span>
        </div>
      </article>

      <p class="dash-group-title" style="grid-column:1 / -1;">Model usage and cost-efficiency proxy</p>

      <article class="card chart-card span-4" aria-label="Token mix">
        <div class="chart-head">
          <div>
            <div class="chart-title">Token mix</div>
            <div class="chart-sub">Prompt vs completion share of all tracked tokens.</div>
          </div>
        </div>
        <div class="chart-canvas" id="tokenMixChart" style="height:220px;"></div>
        <div id="tokenMixLegend" class="chart-legend" aria-hidden="true"></div>
      </article>

      <article class="card chart-card span-4" aria-label="Token distribution">
        <div class="chart-head">
          <div>
            <div class="chart-title">Token distribution</div>
            <div class="chart-sub">Documents grouped by total tokens per analysis.</div>
          </div>
        </div>
        <div class="chart-canvas" id="tokenDistributionChart" style="height:220px;"></div>
      </article>

      <article class="card chart-card span-4" aria-label="Document type distribution">
        <div class="chart-head">
          <div>
            <div class="chart-title">Document types</div>
            <div class="chart-sub">Top types among processed documents.</div>
          </div>
        </div>
        <div class="chart-canvas" id="documentTypeChart" style="height:220px;"></div>
      </article>

      <article class="card chart-card span-8" aria-label="Today throughput">
        <div class="chart-head">
          <div>
            <div class="chart-title">Today throughput</div>
            <div class="chart-sub">Documents processed per hour since midnight.</div>
          </div>
          <div class="chart-sub"><strong id="todayTotal">${(s.today && s.today.total) ? s.today.total.toLocaleString() : '0'}</strong> today</div>
        </div>
        <div class="chart-canvas" id="timelineChart"></div>
      </article>

      <article class="card chart-card span-4" aria-label="Token efficiency">
        <div class="chart-head">
          <div>
            <div class="chart-title">Cost &amp; efficiency</div>
            <div class="chart-sub">Estimated spend and token averages per document.</div>
          </div>
        </div>
        ${
          hasMetrics
          ? `
          <div class="kpi" style="box-shadow:none;border-color:transparent;background:var(--bg-strong);">
            ${cost.available ? `
            <div class="kpi-label">Estimated total${cost.isEstimate ? ' *' : ''}</div>
            <div class="kpi-value">${fmtUsd(cost.total)}</div>
            <div class="kpi-context"><strong>${fmtCents(cost.perDocument)}</strong> / document &middot; ${cost.model}</div>
            <div class="chart-legend" style="margin-top:0.5rem;">
              <span class="legend-item"><span class="legend-dot" style="background:#8b5cf6"></span>Input ${fmtCents(cost.inputCost)}</span>
              <span class="legend-item"><span class="legend-dot" style="background:#22c55e"></span>Output ${fmtCents(cost.outputCost)}</span>
            </div>
            ${cost.savings > 0 ? `<div class="cost-anchor"><span>Manual filing would cost about <s>${fmtUsd(cost.manualEquivalent)}</s></span><strong>You saved ${fmtUsd(cost.savings)}</strong></div>` : ''}
            <div class="kpi-context" style="margin-top:0.5rem;">Avg ${Math.round(tokens.avgTotal).toLocaleString()} tokens/doc &middot; ${tokens.promptPct}% prompt / ${tokens.completionPct}% completion</div>
            ${cost.isEstimate ? `<div class="kpi-context" style="opacity:0.75;">* Estimate at $${cost.rate.input}/$${cost.rate.output} per 1M input/output tokens. Actual provider billing may differ.</div>` : ''}
            ` : `
            <div class="kpi-label">Avg tokens / document</div>
            <div class="kpi-value">${Math.round(tokens.avgTotal).toLocaleString()}</div>
            <div class="kpi-context">Prompt ${Math.round(tokens.avgPrompt).toLocaleString()} &middot; Completion ${Math.round(tokens.avgCompletion).toLocaleString()}</div>
            <div class="kpi-context">Total tracked: <strong>${tokens.overall.toLocaleString()}</strong> tokens &middot; local model, no cost</div>
            `}
          </div>`
          : `<div class="empty-state"><span class="empty-title">No token metrics yet</span><span>Run a scan to start collecting per-document token usage.</span></div>`
        }
      </article>
    </section>

    <section id="dashboardModal" class="modal" aria-hidden="true">
      <div class="modal-backdrop" data-close-modal></div>
      <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="dashboardModalTitle">
        <div class="page-header" style="margin-bottom:1rem;align-items:center;">
          <h2 id="dashboardModalTitle" style="margin:0;font-size:1.4rem;">Details</h2>
          <button type="button" class="button-secondary" data-close-modal>Close</button>
        </div>
        <div id="dashboardModalContent"></div>
      </div>
    </section>
  `;
%>
<%- include('partials/app-shell', {
  title: 'Dashboard | Tagvico AI',
  activePage: 'dashboard',
  version,
  includeCharts: true,
  includeDataTables: false,
  extraHead: '',
  extraScripts: `<script>window.dashboardPageData = ${dashboardJson};</script><script src="/js/dashboard.js"></script>`,
  body
}) %>
