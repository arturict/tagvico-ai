{
  "name": "tagvico-ai",
  "version": "3.1.1",
  "description": "Tagvico — the private action center and household companion for Paperless-ngx.",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || ^24.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "start": "node scripts/start-production.js",
    "start:backend": "node dist/server.js",
    "start:web": "next start -p 3000",
    "auth:copilot": "node scripts/copilot-login.js",
    "dev": "next dev -p 3000",
    "dev:backend": "npm run build:backend && set TAGVICO_AI_PORT=3001&& nodemon --watch services --watch routes --watch models --watch config --watch server.ts --ext ts,json --exec \"npm run build:backend && node dist/server.js\"",
    "build": "npm run build:backend && npm run build:web",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:web": "node scripts/build-web.js",
    "test": "npm run check && npm run test:unit",
    "test:unit": "npm run build && node scripts/run-tests.js",
    "test:release-acceptance": "node scripts/release-acceptance.mjs",
    "test:release-acceptance:local": "node scripts/run-release-acceptance-local.mjs",
    "check": "npm run typecheck && npm run lint && npm run check:type-debt && npm run check:branding && npm run check:ejs && npm run check:browser && npm run check:settings-architecture",
    "check:browser": "node --check public/js/app-shell.js",
    "check:settings-architecture": "node scripts/check-settings-architecture.js",
    "docs:build": "node scripts/docs.mjs build",
    "docs:dev": "node scripts/docs.mjs dev v3",
    "docs:new-major": "node scripts/docs.mjs new-major",
    "docs:preview": "node scripts/docs.mjs preview v3",
    "check:branding": "node scripts/check-brand-debt.js",
    "check:ejs": "node scripts/check-ejs.js",
    "check:type-debt": "node scripts/check-type-debt.js",
    "typecheck": "npm run typecheck:backend && npm run typecheck:web",
    "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint eslint.config.mjs"
  },
  "keywords": [
    "paperless-ngx",
    "document-ai",
    "self-hosted",
    "ollama",
    "homelab",
    "docker",
    "document-management"
  ],
  "nodemonConfig": {
    "ignore": [
      "test/*",
      "docs/*",
      "node_modules/*",
      ".git/*",
      "*.log",
      "public/*",
      "views/*",
      "document.json",
      "OPENAPI/openapi.json"
    ]
  },
  "author": "arturict",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "3.0.86",
    "@ai-sdk/openai-compatible": "2.0.62",
    "@ai-sdk/react": "3.0.232",
    "@anthropic-ai/sdk": "^0.109.0",
    "@github/copilot-sdk": "^1.0.6",
    "@openai/codex-sdk": "^0.144.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/postcss": "4.3.3",
    "ai": "6.0.230",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "geist": "1.7.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "1.25.0",
    "next": "16.2.11",
    "node-cron": "^4.5.0",
    "nodemon": "^3.1.9",
    "openai": "^4.86.2",
    "parseurl": "^1.3.3",
    "radix-ui": "^1.6.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rimraf": "^6.0.1",
    "shiki": "3.23.0",
    "streamdown": "2.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "tiktoken": "^1.0.20",
    "tw-animate-css": "^1.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.22.0",
    "eslint-config-next": "16.2.11",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jsdoc": "^50.6.3",
    "globals": "^16.0.0",
    "postcss": "8.5.20",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "better-sqlite3"
    ]
  },
  "overrides": {
    "postcss": "8.5.20",
    "sharp": "0.35.3",
    "vite": "6.4.3"
  }
}
