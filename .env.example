PAPERLESS_API_URL=http://paperless:8000
PAPERLESS_API_TOKEN=
PORT=3000
API_KEY=
JWT_SECRET=
CORS_ORIGINS=
TRUST_PROXY=no
ALLOW_REMOTE_SETUP=no
GLOBAL_RATE_LIMIT_MAX=1000
AI_PROVIDER=openrouter
AI_MODEL=openai/gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
