<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <%- include('app-head', { title, includeCharts, includeDataTables, extraHead }) %>
</head>
<body>
  <button id="themeToggle" class="theme-toggle" type="button" aria-label="Toggle theme">
    <i class="fa-solid fa-moon"></i>
  </button>
  <button id="sidebarToggle" class="sidebar-toggle" type="button" aria-label="Toggle navigation">
    <i class="fa-solid fa-bars"></i>
  </button>
  <div id="sidebarOverlay" class="sidebar-overlay"></div>

  <div class="app-shell">
    <%- include('app-sidebar', { activePage, version }) %>
    <main class="app-main">
      <%- body %>
    </main>
  </div>

  <script>
    window.TagvicoAIApp = {
      version: <%- JSON.stringify(version || '') %>,
      activePage: <%- JSON.stringify(activePage || '') %>
    };
  </script>
  <script src="/js/app-shell.js"></script>
  <script src="/js/update-check.js" defer></script>
  <% if (includeDataTables) { %>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
  <% } %>
  <% if (extraScripts) { %>
  <%- extraScripts %>
  <% } %>
</body>
</html>
