<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <%- include('partials/app-head', { title: 'Login | Tagvico AI', includeCharts: false, includeDataTables: false, extraHead: '' }) %>
</head>
<body>
  <button id="themeToggle" class="theme-toggle" type="button" aria-label="Toggle theme">
    <i class="fa-solid fa-moon"></i>
  </button>

  <main style="min-height:100vh;display:grid;place-items:center;padding:1.5rem;">
    <section class="hero" style="width:min(100%,480px);display:grid;gap:1.25rem;">
      <div>
        <div class="badge">Tagvico AI</div>
        <h1 class="page-title" style="font-size:2.2rem;margin-top:0.75rem;">Sign in</h1>
        <p class="page-subtitle">Use your local admin account to manage models, filing behavior, and manual review.</p>
      </div>

      <% if (error) { %>
      <div class="danger"><%= error %></div>
      <% } %>

      <form action="/login" method="POST" class="stack">
        <div class="field">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" required autocomplete="username">
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" required autocomplete="current-password">
        </div>

        <button type="submit" class="button">Sign in</button>
      </form>
    </section>
  </main>

  <script src="/js/app-shell.js"></script>
</body>
</html>
