<%
  const navItems = [
    { href: '/actions', key: 'actions', icon: 'fa-solid fa-list-check', label: 'Action center' },
    { href: '/companion', key: 'companion', icon: 'fa-solid fa-wand-magic-sparkles', label: 'Companion' },
    { href: '/settings', key: 'household', icon: 'fa-solid fa-users-gear', label: 'Household & models' },
    { href: '/dashboard', key: 'dashboard', icon: 'fa-solid fa-chart-line', label: 'Document automation' },
    { href: '/history', key: 'history', icon: 'fa-solid fa-clock-rotate-left', label: 'History' },
    { href: '/operations', key: 'operations', icon: 'fa-solid fa-tower-broadcast', label: 'Operations' },
    { href: '/automation/settings', key: 'settings', icon: 'fa-solid fa-sliders', label: 'Automation settings' }
  ];
%>
<aside class="app-sidebar" id="appSidebar">
  <button id="desktopSidebarToggle" class="desktop-sidebar-toggle" type="button" aria-label="Collapse navigation" aria-expanded="true">
    <i class="fa-solid fa-angles-left"></i>
  </button>
  <div class="app-brand">
    <img class="app-brand-mark" src="/tagvico-icon.png" alt="Tagvico AI icon">
    <div class="app-brand-copy">
      <div class="app-brand-title">Tagvico AI</div>
      <div class="app-brand-subtitle">AI filing for Paperless-ngx</div>
    </div>
  </div>

  <nav class="app-nav">
    <% navItems.forEach((item) => { %>
      <a href="<%= item.href %>" class="app-nav-link <%= activePage === item.key ? 'is-active' : '' %>">
        <i class="<%= item.icon %>" aria-hidden="true"></i>
        <span><%= item.label %></span>
      </a>
    <% }) %>
    <a href="/logout" class="app-nav-link">
      <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
      <span>Logout</span>
    </a>
  </nav>

  <div class="app-sidebar-footer">
    <div id="appUpdateBanner" class="app-update-banner" hidden>
      <i class="fa-solid fa-circle-up"></i>
      <span class="app-update-banner-text">New update available</span>
      <a href="#" class="app-update-banner-link" target="_blank" rel="noreferrer">View</a>
      <button class="app-update-banner-dismiss" type="button" aria-label="Dismiss update notification">×</button>
    </div>
    <a href="/manual" class="app-github">
      <span>
        <i class="fa-solid fa-file-pen"></i>
        Manual review
      </span>
    </a>
    <a href="https://github.com/arturict/tagvico-ai" class="app-github" target="_blank" rel="noreferrer">
      <span>
        <i class="fa-brands fa-github"></i>
        Star on GitHub
      </span>
      <strong id="starCount">...</strong>
    </a>
    <p>Rebuilt for current model workflows and cleaner Paperless-ngx filing operations.</p>
  </div>
</aside>
